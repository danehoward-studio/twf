{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/athletes.js": { "runtime": "nodejs18.x" },
    "api/speak.js":    { "runtime": "nodejs18.x" }
  },
  "routes": [
    { "src": "/api/athletes", "dest": "/api/athletes.js" },
    { "src": "/api/speak",    "dest": "/api/speak.js" },
    { "src": "/(.*)",         "dest": "/$1" }
  ]
}
